# ─────────────────────────────────────────────────────────────────────────────
#  GarganDeFi Bot — .env.example
#  Copy this to .env and fill in real values. NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord boundaries ───────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_GUILD_ID=YOUR_GUILD_ID_HERE                   # integer

# 🔒 PRIVATE WEALTH MANAGER (DeFi Ops - YOU ONLY)
DISCORD_OWNER_ID=YOUR_DISCORD_USER_ID                 # integer, HITL approver
DISCORD_PRIVATE_DEFI_CHANNEL_ID=YOUR_PRIVATE_DEFI_ID  # Raydium Auto-Zap, wallet balances, actionable Embeds

# 📢 FREEMIUM SAAS (Community Public Facing)
DISCORD_PUBLIC_DEALS_ID=YOUR_PUBLIC_DEALS_ID          # Scraped hardware deals with affiliate tags
DISCORD_PUBLIC_SIGNALS_ID=YOUR_PUBLIC_SIGNALS_ID      # Teaser signals (Free) - e.g. "Bullish setup on $RAY..."
DISCORD_VIP_SIGNALS_ID=YOUR_VIP_SIGNALS_ID            # Actionable signals (VIP) - Full TA, entry, stop loss
DISCORD_SYS_LOGS_ID=YOUR_SYS_LOGS_ID                  # Temperature warnings and boot messages

# ── Solana RPC ─────────────────────────────────────────────────────────────────
# Use a paid RPC for production (QuickNode, Helius, Triton, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS_URL=wss://api.mainnet-beta.solana.com

# ── Burner Wallet ─────────────────────────────────────────────────────────────
# Base-58 encoded private key. Keep this secret!
# Generate with: python -c "from solders.keypair import Keypair; k=Keypair(); print(k.to_base58_string())"
WALLET_PRIVATE_KEY_BASE58=YOUR_BASE58_PRIVATE_KEY_HERE

# ── DeFi Engine Config ────────────────────────────────────────────────────────
# How many SOL to keep reserved for gas at all times
GAS_RESERVE_SOL=0.02

# Whether the bot auto-switches pools without human approval
# Set to false for HITL (Human-In-The-Loop) mode  ← recommended
AUTONOMOUS_POOL_SWITCHING=false

# Minimum APY improvement (in %) that triggers an alert/migration proposal
MIN_APY_IMPROVEMENT_THRESHOLD=5.0

# Maximum acceptable Impermanent Loss % before bot refuses a migration
MAX_IL_TOLERANCE_PCT=10.0

# Pool scan interval in seconds
POOL_SCAN_INTERVAL_SECONDS=300

# ── Active Pool (updated programmatically by !approve_migration) ──────────────
# Raydium AMM pool IDs — see https://raydium.io/pools/
ACTIVE_POOL_ID=58oQChx4yWmvKnVgSTweG8AntmDhmr57fCz5rqVGkS8J   # SOL/USDC default
ACTIVE_POOL_BASE_MINT=So11111111111111111111111111111111111111112   # Wrapped SOL
ACTIVE_POOL_QUOTE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v  # USDC

# ── Jupiter API ────────────────────────────────────────────────────────────────
JUPITER_API_BASE=https://api.jup.ag/swap/v1
# Slippage tolerance in basis points (50 = 0.5%)
JUPITER_SLIPPAGE_BPS=50

# ── Hardware Deals Scraper ────────────────────────────────────────────────────
# Comma-separated keywords to match deals against
DEALS_KEYWORDS=GPU,RTX,RX 7900,RX 6800,Arc B580,mini-PC,NUC,Ryzen,Core Ultra,OLED,SSD
# Keywords that completely disqualify a deal
DEALS_BANNED_KEYWORDS=refurbished,used,open box,parts only,broken,finance,monthly,sweepstakes,giveaway
# Minimum discount percentage to report
DEALS_MIN_DISCOUNT_PCT=20
# Scan interval for deals in seconds
DEALS_SCAN_INTERVAL_SECONDS=600
# Your referral/affiliate tag (appended to deal URLs if supported)
DEALS_AFFILIATE_TAG=

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/gargandefi.db

# ── Streamlit Dashboard ───────────────────────────────────────────────────────
DASHBOARD_PORT=8501

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Minimum investable SOL (total - gas_reserve must be >= this)
MIN_INVEST_SOL=0.05
